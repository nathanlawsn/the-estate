---
import { Icon } from 'astro-icon';

const { heading } = Astro.props;

import hero001 from '../images/hero-001.jpg';
import hero002 from '../images/hero-002.jpg';
---
<section class="grid sm:grid-cols-2 relative h-[75vh]">

    <div class="bg-slate-700 relative group overflow-hidden cursor-pointer">
        <img class="object-cover w-full h-full group-hover:scale-110 duration-[3000ms] transition-transform block" src={hero001} alt="A man standing on a mountain">
        <a class="bg-orange-400 text-white flex items-center gap-5 justify-between sm:gap-[4.75rem] px-5 md:px-11 py-3 min-h-[6.25rem] w-full absolute bottom-0 group-hover:bg-primary-purple transition-colors duration-500 ease-in-out" href="#">
            <span class="text-[2.125rem]">Book now</span>
            <span class="block w-8 h-8 group-hover:rotate-45 duration-500 ease-in-out">
                <Icon name="arrow" />
            </span>
        </a>
    </div>

    <div class="bg-slate-600 hidden sm:block group overflow-hidden">
        <img class="object-cover w-full h-full group-hover:scale-110 duration-[3000ms] transition-transform block" src={hero002} alt="A boat on a lake">
    </div>

    <h1 class="text-[3.125rem] text-white text-center left-0 right-0 text-4xl absolute top-1/2 -translate-y-1/2">{heading}</h1>

</section>